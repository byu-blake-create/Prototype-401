# Database Configuration
DB_USER=postgres
DB_HOST=localhost
DB_NAME=gylt
DB_PASSWORD=your_password_here
DB_PORT=5432

# Server Configuration
PORT=5057

# Instructions:
# 1. Copy this file to backend/.env
